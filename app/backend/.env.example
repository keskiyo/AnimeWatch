# MongoDB connection (hosting provides the URI). Local dev: Docker `mongo:7`
# or MongoDB Atlas. The DB name is created on first write.
DB_CONNECTION_STRING_MONGODB=mongodb://localhost:27017
DBNAME_MONGODB=animewatch
# Compatibility aliases (used only if the *_MONGODB names above are unset):
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=animewatch
# Only for the one-time migration script scripts/migrate_sqlite_to_mongo.py.
# Falls back to DATABASE_PATH if set.
LEGACY_SQLITE_PATH=./data/anime-viewer.db
# Local file storage (uploaded avatars live in $DATA_DIR/avatars).
DATA_DIR=./data
CACHE_TTL_SECONDS=3600
SHIKIMORI_ENDPOINT=https://shikimori.one
SHIKIMORI_GQL_ENDPOINT=https://shikimori.io/api/graphql
SHIKIMORI_USER_AGENT=AnimeWatch/0.1 (local development)
KODIK_ENDPOINT=https://kodik-api.com
KODIK_API_KEY=
# YummyAnime (yani.tv) — fallback descriptions only. Without a token this source
# is skipped (no hardcoded fallback). PRIVATE takes precedence over PUBLIC.
YUMMYANIME_API_ENDPOINT=https://api.yani.tv
YUMMYANIME_PRIVATE_TOKEN=
YUMMYANIME_PUBLIC_TOKEN=
# Comma-separated production origins allowed by CORS (the SPA's public URL).
# Localhost dev ports (5173/5174) are always allowed.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin sync endpoints (/admin/sync/shikimori/*). When empty, only localhost
# is allowed; set a secret in production and send it as X-Admin-Token.
ADMIN_SYNC_TOKEN=

# When the local `anime` collection is empty, /api/anime/bulk normally
# returns [] and asks for a sync. Set true to allow the legacy direct
# Shikimori bulk fetch as a fallback (off by default to protect API limits).
ALLOW_SHIKIMORI_BULK_FALLBACK=false

# Cron-triggered catalog refresh (POST /internal/catalog/refresh).
# BACKEND_URL is used only by the cron job itself (see deploy/cron/).
# Without CATALOG_REFRESH_TOKEN the endpoint answers 503 to everyone.
BACKEND_URL=http://127.0.0.1:3001
CATALOG_REFRESH_TOKEN=
CATALOG_REFRESH_TIMEOUT_MS=7200000

# Public site origin used for absolute URLs in robots.txt / sitemap.xml and the
# server-side SEO <head> (routers/frontend_host.py). Empty = derive from the
# request (works behind a reverse proxy). Set in production to your real domain,
# e.g. https://animewatch.example.
SITE_URL=

# Built SPA directory the backend serves with server-side SEO injection.
# Default: ../frontend/dist relative to the backend. Run `bun run build` first.
FRONTEND_DIST=
